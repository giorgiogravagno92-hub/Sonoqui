datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String          @id @default(uuid())
  email        String          @unique
  passwordHash String
  role         String          // "WORKER", "COMPANY", "ADMIN"
  createdAt    DateTime        @default(now())
  workerProfile WorkerProfile?
  companyProfile CompanyProfile?
  notifications Notification[]
}

model WorkerProfile {
  id                   String             @id @default(uuid())
  userId               String             @unique
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName            String
  lastName             String
  photoUrl             String?
  city                 String
  province             String
  sigla                String?
  region               String
  profession           String
  educationLevel       String             @default("NESSUNO") // "NESSUNO", "LICENZA_MEDIA", "DIPLOMA", "LAUREA"
  educationField       String?            // Specific diploma or degree
  educationTitles      String             @default("[]")      // JSON array of multiple education degrees
  skills               String             // Comma-separated list of skills
  certifications       String?            // Comma-separated list of certifications
  hasLicense           Boolean            @default(false)
  hasCar               Boolean            @default(false)
  availabilityStatus   String             // "DISPONIBILE_PROPOSTE", "NON_DISPONIBILE"
  availabilityDetails  String?            // e.g. "Lun-Ven, Mattina"
  maxDistanceKm        Int                @default(50)
  desiredContract      String?            // e.g. "TEMPO_INDETERMINATO", "PART_TIME", "APPRENDISTATO"
  desiredSalary        String?            // Optional salary range or figure
  availabilityRegionsProvinces String   @default("[]")
  availabilityContracts        String   @default("[]")
  availabilityRoles            String   @default("[]")
  notes                        String?
  availabilityNotes            String?
  cvPdfUrl             String?
  videoPresentationUrl String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  favoritedBy          Favorite[]
  interviewRequests    InterviewRequest[]
  workExperiences      WorkExperience[]
  proposalResponses    ProposalResponse[]
}

model CompanyProfile {
  id                String             @id @default(uuid())
  userId            String             @unique
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyType       String             @default("AZIENDA") // "AZIENDA" or "PERSONA_FISICA"
  companyName       String?
  address           String?
  vatNumber         String?
  firstName         String?
  lastName          String?
  residenzaCapCitta String?
  fiscalCode        String?
  industry          String?
  city              String?
  province          String?
  sigla             String?
  contactPerson     String?
  contactPhone      String?
  logoUrl           String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  favorites         Favorite[]
  interviewRequests InterviewRequest[]
  jobProposals      JobProposal[]
}

model JobProposal {
  id                String             @id @default(uuid())
  companyId         String
  company           CompanyProfile     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  professions       String             // JSON array of string professions
  locations         String             // JSON array of location objects [{ city, province, sigla }]
  educationTitle    String             // "Nessuna preferenza", "LICENZA_MEDIA", "DIPLOMA", "LAUREA"
  hasLicense        Boolean            @default(false)
  hasCar            Boolean            @default(false)
  minSalary         String?
  maxSalary         String?
  notes             String?
  status            String             @default("ACTIVE") // "DRAFT" or "ACTIVE"
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  responses         ProposalResponse[]
}

model ProposalResponse {
  id          String        @id @default(uuid())
  proposalId  String
  proposal    JobProposal   @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  workerId    String
  worker      WorkerProfile @relation(fields: [workerId], references: [id], onDelete: Cascade)
  status      String        // "ACCEPTED" or "DECLINED"
  createdAt   DateTime      @default(now())

  @@unique([proposalId, workerId])
}

model Favorite {
  id              String         @id @default(uuid())
  companyId       String
  company         CompanyProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)
  workerId        String
  worker          WorkerProfile  @relation(fields: [workerId], references: [id], onDelete: Cascade)
  createdAt       DateTime       @default(now())

  @@unique([companyId, workerId])
}

model InterviewRequest {
  id            String         @id @default(uuid())
  companyId     String
  company       CompanyProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)
  workerId      String
  worker        WorkerProfile  @relation(fields: [workerId], references: [id], onDelete: Cascade)
  message       String
  interviewDate String
  status        String         // "PENDING", "ACCEPTED", "DECLINED"
  createdAt     DateTime       @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  read      Boolean  @default(false)
  type      String   // "PROFILE_VIEW", "MESSAGE", "INTERVIEW_REQUEST", "EXPIRING_AVAILABILITY"
  createdAt DateTime @default(now())
}

model WorkExperience {
  id              String        @id @default(uuid())
  workerProfileId String
  workerProfile   WorkerProfile @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  companyName     String
  role            String
  startDate       String
  endDate         String?
  description     String?
  city            String?
  province        String?
  sigla           String?
  createdAt       DateTime      @default(now())
}

